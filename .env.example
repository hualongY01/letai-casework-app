LETAI_APP_ENV=local
LETAI_DB_PATH=./storage/letai_factbase.sqlite3
LETAI_STORAGE_ROOT=./storage
LETAI_VAULT_EXPORT_DIR=./storage/vault_readonly

# Optional. If unset, import, parsing, OCR, indexing and manual review still work.
LETAI_LLM_PROVIDER=openai
LETAI_LLM_API_KEY=
LETAI_LLM_API_BASE=https://api.openai.com/v1
LETAI_LLM_MODEL=
LETAI_LLM_TIMEOUT_SECONDS=60
LETAI_LLM_MAX_CANDIDATES=8
